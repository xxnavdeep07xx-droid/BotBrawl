// AI Chess Gladiator — Phase 2 schema
// Learn more about Prisma: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Users — simplified: one demo user for Phase 2 beta, but the schema is
// multi-user-ready for when auth lands.
// ---------------------------------------------------------------------------
model User {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  computeTokens   Int      @default(1000)
  lastTokenGrant  DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bets Bet[]
  chatMessages ChatMessage[]
}

// ---------------------------------------------------------------------------
// AI Players — one row per (provider, model, persona) combination.
// Elo starts at 1200 (chess.com-ish default).
// ---------------------------------------------------------------------------
model AIPlayer {
  id         String  @id @default(cuid())
  name       String                  // display name e.g. "GPT-4o-mini"
  provider   String                  // "zai" (single backend in Phase 2)
  model      String                  // model slug
  personaKey String                  // persona key from src/lib/personas.ts
  elo        Int     @default(1200)
  wins       Int     @default(0)
  losses     Int     @default(0)
  draws      Int     @default(0)
  createdAt  DateTime @default(now())

  matchesAsWhite Match[]   @relation("MatchWhite")
  matchesAsBlack Match[]   @relation("MatchBlack")
  tournamentSlots TournamentSlot[]
}

// ---------------------------------------------------------------------------
// Matches
// ---------------------------------------------------------------------------
model Match {
  id           String    @id @default(cuid())
  whiteId      String
  blackId      String
  status       String    @default("UPCOMING")  // UPCOMING | LIVE | COMPLETED
  winner       String?                            // "white" | "black" | null (draw)
  reason       String?                            // why the match ended
  finalFen     String?
  pgn          String?                            // full game in PGN
  plies        Int       @default(0)
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  white        AIPlayer  @relation("MatchWhite", fields: [whiteId], references: [id])
  black        AIPlayer  @relation("MatchBlack", fields: [blackId], references: [id])
  events       MatchEvent[]
  bets         Bet[]
  highlights   Highlight[]
  chatMessages ChatMessage[]
  tournamentMatches TournamentMatch[]

  @@index([status])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Per-move events — one row per half-move (or special event like resignation)
// ---------------------------------------------------------------------------
model MatchEvent {
  id          String   @id @default(cuid())
  matchId     String
  ply         Int                       // 1-indexed half-move number
  side        String                    // "white" | "black" | ""
  type        String                    // "match_start" | "move" | "player_resigned" | "player_timeout" | "match_end"
  san         String?                   // SAN move (if applicable)
  monologue   String?                   // player's narration
  retries     Int      @default(0)
  apiErrors   Int      @default(0)
  elapsedMs   Int      @default(0)
  timestamp   DateTime @default(now())

  match       Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId, ply])
}

// ---------------------------------------------------------------------------
// Bets — users wager Compute Tokens on which AI will win
// ---------------------------------------------------------------------------
model Bet {
  id        String   @id @default(cuid())
  userId    String
  matchId   String
  side      String                           // "white" | "black"
  amount    Int                              // tokens wagered
  payout    Int?                             // tokens returned (null until settled)
  status    String   @default("PENDING")    // PENDING | WON | LOST | DRAWN | REFUNDED
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  match     Match    @relation(fields: [matchId], references: [id])

  @@index([userId])
  @@index([matchId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Highlights — auto-detected blunders from completed matches, rendered as
// 9:16 vertical video clips for TikTok / YouTube Shorts. (Phase 3)
// ---------------------------------------------------------------------------
model Highlight {
  id           String    @id @default(cuid())
  matchId      String
  ply          Int                            // half-move at which the blunder happened
  side         String                         // "white" | "black" — who blundered
  blunderType  String                         // "ILLEGAL_RETRIES" | "RESIGNATION" | "MATERIAL_LOSS" | "TIMEOUT"
  blunderScore Int                            // 0–100, higher = funnier
  title        String                         // auto-generated clip title
  monologue    String                         // the AI's narration at this moment
  san          String?                        // the move (if applicable)
  fenBefore    String                         // board state BEFORE the blunder
  fenAfter     String?                        // board state AFTER (null if no legal move was made)
  videoPath    String?                        // relative path under /public, e.g. "highlights/abc.mp4"
  status       String    @default("PENDING")  // PENDING | RENDERING | RENDERED | FAILED
  createdAt    DateTime  @default(now())
  renderedAt   DateTime?

  match        Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@index([blunderScore])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Tournaments — bracket-style AI competitions. (Phase 4)
//
// A Tournament has N rounds (log2(size) for single-elim). Each round has
// size/2^round matches. The winner of each match advances to the next round
// as white or black in their next match.
// ---------------------------------------------------------------------------
model Tournament {
  id           String   @id @default(cuid())
  name         String
  format       String   @default("SINGLE_ELIM")  // SINGLE_ELIM (only one supported in v1)
  size         Int      @default(4)              // 4 | 8 (16 possible but UI not optimized for it)
  status       String   @default("UPCOMING")     // UPCOMING | ACTIVE | COMPLETED
  currentRound Int      @default(0)              // 0-indexed
  winnerId     String?                            // AIPlayer id of tournament champion
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime @default(now())

  slots       TournamentSlot[]
  matches     TournamentMatch[]

  @@index([status])
}

// One slot per AI player in the tournament. Seeded at creation time.
model TournamentSlot {
  id            String    @id @default(cuid())
  tournamentId  String
  seed          Int                              // 1-indexed seed (1 = highest Elo)
  playerId      String                           // AIPlayer id
  eliminated    Boolean   @default(false)
  eliminatedIn  Int?                             // round number when eliminated

  tournament    Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player        AIPlayer   @relation(fields: [playerId], references: [id])
  whiteInMatches  TournamentMatch[] @relation("TournamentMatchWhiteSlot")
  blackInMatches  TournamentMatch[] @relation("TournamentMatchBlackSlot")
  winnerInMatches  TournamentMatch[] @relation("TournamentMatchWinnerSlot")

  @@unique([tournamentId, seed])
  @@index([tournamentId])
}

// A single match in a tournament bracket. The first round is seeded at
// tournament start; subsequent rounds are filled in as winners advance.
model TournamentMatch {
  id            String    @id @default(cuid())
  tournamentId  String
  round         Int                                // 0-indexed round
  bracketIndex  Int                                // position within the round (0..size/2^(round+1)-1)
  matchId       String?                            // linked Match when scheduled
  whiteSlotId   String?                            // TournamentSlot
  blackSlotId   String?
  winnerSlotId  String?
  status        String    @default("PENDING")     // PENDING | READY | LIVE | COMPLETED

  tournament    Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  match         Match?     @relation(fields: [matchId], references: [id])
  whiteSlot     TournamentSlot? @relation("TournamentMatchWhiteSlot", fields: [whiteSlotId], references: [id])
  blackSlot     TournamentSlot? @relation("TournamentMatchBlackSlot", fields: [blackSlotId], references: [id])
  winnerSlot    TournamentSlot? @relation("TournamentMatchWinnerSlot", fields: [winnerSlotId], references: [id])

  @@unique([tournamentId, round, bracketIndex])
  @@index([tournamentId, round])
}

// ---------------------------------------------------------------------------
// Chat messages — spectator chat for live matches. (Phase 4)
// ---------------------------------------------------------------------------
model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  matchId   String                            // which match's chat (no tournament-level chat in v1)
  content   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId, createdAt])
}
